# Database
# Node 跑在 host，連容器 DB 走 localhost:5432 (docker-compose.production.yml
# 已把 db 綁到 127.0.0.1:5432)
DATABASE_URL=postgresql://comux:comux@localhost:5432/comux?schema=public
POSTGRES_PASSWORD=comux

# Auth JWT secret (generate with: openssl rand -hex 32)
COMUX_SECRET=change-me-in-production

# Production
PROJECTS_ROOT=/home/devops/projects

# Domain (nginx-proxy / acme-companion 從 prod-proxy 容器讀到這個值簽憑證)
VIRTUAL_HOST=comux.yoursite.com
LETSENCRYPT_EMAIL=you@example.com

# WebSocket origin allowlist (comma-separated hostnames)
ALLOWED_ORIGINS=comux.yoursite.com,localhost

# Cloudflare (選用，DNS 管理功能才需要)
CF_API_TOKEN=
CF_ZONE_ID=

# Dev only
NEXT_PUBLIC_WS_PORT=3001
