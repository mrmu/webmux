# Database
DATABASE_URL=postgresql://webmux:webmux@localhost:5432/webmux?schema=public
POSTGRES_PASSWORD=webmux

# Auth JWT secret (generate with: openssl rand -hex 32)
WEBMUX_SECRET=change-me-in-production

# Production (Linux) — match host dev user for tmux socket access
# Run: id -u && id -g
HOST_UID=1000
HOST_GID=1000
HOST_USER_HOME=/home/devops
PROJECTS_ROOT=/var/docker-www/wp-proxy-sites

# Domain
VIRTUAL_HOST=webmux.yoursite.com
LETSENCRYPT_EMAIL=you@example.com

# WebSocket origin allowlist (comma-separated hostnames)
ALLOWED_ORIGINS=webmux.yoursite.com,localhost

# Dev only
NEXT_PUBLIC_WS_PORT=3001
