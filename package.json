{
  "name": "webmux",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx tsx ws-dev-server.ts & NEXT_PUBLIC_WS_PORT=3001 npx next dev",
    "build": "env -u TURBOPACK -u __NEXT_PRIVATE_STANDALONE_CONFIG -u NEXT_DEPLOYMENT_ID -u __NEXT_PROCESSED_ENV sh -c 'npx prisma generate && next build'",
    "start": "NODE_ENV=production npx tsx server.ts",
    "lint": "eslint",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "postinstall": "test -f prisma/schema.prisma && npx prisma generate || true"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pg": "^8.20.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.4",
    "node-pty": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
